# Copy this file to ~/.config/codex-telegram-bridge/config.env
# or point the CLI to it with --config-env-file.
# Restrict access because it contains bot credentials.

# Required runtime settings
CODEX_TELEGRAM_BRIDGE_TELEGRAM_BOT_TOKEN=123456:replace-me
# Generated by `codex-telegram-bridge setup`; do not write plaintext here.
CODEX_TELEGRAM_BRIDGE_VERIFICATION_PASSWORD_HASH=scrypt$16384$8$1$32$replace-with-generated-salt$replace-with-generated-hash
CODEX_TELEGRAM_BRIDGE_OWNER_TELEGRAM_USER_ID=123456789
CODEX_TELEGRAM_BRIDGE_OWNER_TELEGRAM_CHAT_ID=123456789
CODEX_TELEGRAM_BRIDGE_DEFAULT_WORKSPACE_ROOT=/home/your-user/codex-workspaces/main
CODEX_TELEGRAM_BRIDGE_LOG_LEVEL=info

# Optional paths
CODEX_TELEGRAM_BRIDGE_APP_HOME=/home/your-user/.local/share/codex-telegram-bridge
CODEX_TELEGRAM_BRIDGE_CODEX_HOME=/home/your-user/.codex

# Optional privacy and retention settings
# CODEX_TELEGRAM_BRIDGE_AUDIT_LEVEL=minimal
# CODEX_TELEGRAM_BRIDGE_INCLUDE_RUNTIME_IDENTIFIERS=false
# CODEX_TELEGRAM_BRIDGE_MAX_AUDIT_ROWS=1000
# CODEX_TELEGRAM_BRIDGE_RESOLVED_APPROVAL_RETENTION_DAYS=7
# CODEX_TELEGRAM_BRIDGE_EXPIRED_APPROVAL_RETENTION_DAYS=1

# Optional executable override
# CODEX_TELEGRAM_BRIDGE_CODEX_EXECUTABLE=/usr/local/bin/codex

# Notes
# - Use absolute Linux paths.
# - Keep this at a dedicated workspace path.
# - Use `/scope workspace` in Telegram when you want to temporarily narrow
#   access back to the workspace root.
# - Telegram-facing `/cd` paths must stay inside the current allowed set.
