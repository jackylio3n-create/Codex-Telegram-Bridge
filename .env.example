# Required runtime settings for direct Linux deployment
CODEX_TELEGRAM_BRIDGE_TELEGRAM_BOT_TOKEN=123456:replace-me
CODEX_TELEGRAM_BRIDGE_ALLOWED_TELEGRAM_USER_IDS=123456789
CODEX_TELEGRAM_BRIDGE_DEFAULT_WORKSPACE_ROOT=/srv/codex-telegram-bridge/workspaces/main
CODEX_TELEGRAM_BRIDGE_LOG_LEVEL=info

# Optional paths
CODEX_TELEGRAM_BRIDGE_APP_HOME=/var/lib/codex-telegram-bridge
CODEX_TELEGRAM_BRIDGE_CODEX_HOME=/home/bridge/.codex

# Notes
# - Use absolute Linux paths.
# - The workspace root must already exist before `npm run start`.
# - Telegram-facing paths such as /cwd and /adddir must stay inside the
#   workspace root or an explicitly added allowed directory.
