{
  "name": "codex-telegram-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bridge daemon for Codex, designed for direct Linux server deployment.",
  "type": "module",
  "bin": {
    "codex-telegram-bridge": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests",
    "lint:shell": "node scripts/run-shellcheck.mjs scripts/install-ubuntu.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "cli": "tsx src/cli/main.ts",
    "start": "tsx src/cli/main.ts start",
    "serve": "tsx src/cli/main.ts serve",
    "setup": "tsx src/cli/main.ts setup",
    "stop": "tsx src/cli/main.ts stop",
    "status": "tsx src/cli/main.ts status",
    "logs": "tsx src/cli/main.ts logs",
    "doctor": "tsx src/cli/main.ts doctor"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
